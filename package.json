{
  "name": "pdf-unlocker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vike dev --host --port 3000",
    "build": "tsc -b && vike build",
    "lint": "prettier --config .prettierrc \"src/**/*.{ts,js,tsx,jsx}\" --check && eslint \"src/**/*.{ts,js,tsx,jsx}\"",
    "lint:fix": "prettier --config .prettierrc \"src/**/*.{ts,js,tsx,jsx}\" --write && eslint \"src/**/*.{ts,js,tsx,jsx}\" --fix",
    "start": "vike preview --host --port 3000",
    "mkcert": "tsx scripts/mkcert.ts"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-form": "^1.28.5",
    "@tanstack/react-query": "^5.90.21",
    "date-fns": "^4.1.0",
    "pdf-lib": "^1.17.1",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-toastify": "^11.0.5",
    "tailwindcss": "^4.2.1",
    "vike": "^0.4.255",
    "vike-react": "^0.6.21",
    "workbox-core": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0"
  },
  "devDependencies": {
